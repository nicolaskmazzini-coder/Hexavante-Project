# Copie para .env.production na VPS:
# cp .env.production.example .env.production

# Domínio público
AUTH_URL="https://hexavante.com.br"

# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-secret-forte"

# Banco (usado pelo docker-compose.prod.yml)
DB_ROOT_PASSWORD="senha-root-forte"
DB_PASSWORD="senha-app-forte"

# OAuth — use as URLs de produção nos consoles Google/GitHub
# https://hexavante.com.br/api/auth/callback/google
# https://hexavante.com.br/api/auth/callback/github
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

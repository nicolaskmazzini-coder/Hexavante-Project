# Banco de dados
# MariaDB — servidor local ou remoto (ex.: servidor em casa)
DATABASE_URL="mysql://root:SUA_SENHA@IP_DO_SERVIDOR:3306/hexavante"

# Auth.js (obrigatório)
# Gere AUTH_SECRET com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="gere-um-secret-aleatorio-aqui"
# Local: http://localhost:3000 | Produção/tunnel: https://hexavante.com.br
AUTH_URL="http://localhost:3000"

# OAuth — Auth.js v5 usa prefixo AUTH_* (aliases legados também funcionam)
# Google Cloud Console → URIs de redirecionamento autorizados:
#   http://localhost:3000/api/auth/callback/google
#   https://hexavante.com.br/api/auth/callback/google
# GitHub Developer Settings → Authorization callback URL:
#   http://localhost:3000/api/auth/callback/github
#   https://hexavante.com.br/api/auth/callback/github
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
# Aliases opcionais (legado):
# GOOGLE_CLIENT_ID="" GOOGLE_CLIENT_SECRET=""
# GITHUB_ID="" GITHUB_SECRET=""

# Docker: docker compose up -d
# DATABASE_URL="mysql://hexavante:hexavante@localhost:3306/hexavante"

{
  "name": "hexavante",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma educacional Hexavante",
  "scripts": {
    "dev": "node --max-http-header-size=65536 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "postbuild": "node scripts/prepare-standalone.mjs",
    "start": "node --max-http-header-size=65536 .next/standalone/server.js",
    "start:next": "node --max-http-header-size=65536 ./node_modules/next/dist/bin/next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "test": "vitest --config vitest.config.mjs",
    "test:ui": "vitest --config vitest.config.mjs --ui",
    "test:coverage": "vitest --config vitest.config.mjs --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:sync": "prisma db execute --file prisma/sql/add-course-level-columns.sql --schema prisma/schema.prisma",
    "db:sprint5": "prisma db execute --file prisma/sql/sprint-5-notifications.sql --schema prisma/schema.prisma",
    "db:avatar": "prisma db execute --file prisma/sql/avatar-url-longtext.sql --schema prisma/schema.prisma",
    "db:certificates": "prisma db execute --file prisma/sql/certificate-user-course-unique.sql --schema prisma/schema.prisma",
    "db:features": "prisma db execute --file prisma/sql/course-cover-exam-essay.sql --schema prisma/schema.prisma",
    "db:exam-cover": "prisma db execute --file prisma/sql/exam-cover-image.sql --schema prisma/schema.prisma",
    "db:exam-question-image": "prisma db execute --file prisma/sql/exam-question-image.sql --schema prisma/schema.prisma",
    "db:exam-question-image-size": "prisma db execute --file prisma/sql/exam-question-image-size.sql --schema prisma/schema.prisma",
    "db:exam-questions": "npm run db:exam-question-image && npm run db:exam-question-image-size",
    "db:economy": "prisma db execute --file prisma/sql/economy-shop-premium.sql --schema prisma/schema.prisma",
    "db:booster": "prisma db execute --file prisma/sql/user-booster-fields.sql --schema prisma/schema.prisma",
    "db:social": "prisma db execute --file prisma/sql/social-features.sql --schema prisma/schema.prisma",
    "db:moderation": "prisma db execute --file prisma/sql/moderation-admin.sql --schema prisma/schema.prisma",
    "db:superadmin": "prisma db execute --file prisma/sql/superadmin-role.sql --schema prisma/schema.prisma",
    "db:exam-daily-rewards": "prisma db execute --file prisma/sql/exam-daily-reward-fields.sql --schema prisma/schema.prisma",
    "db:shop-expand": "prisma db execute --file prisma/sql/shop-expand-categories.sql --schema prisma/schema.prisma",
    "db:direct-messages": "prisma db execute --file prisma/sql/direct-messages.sql --schema prisma/schema.prisma",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}

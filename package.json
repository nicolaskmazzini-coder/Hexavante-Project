{
  "name": "hexavante",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma educacional Hexavante",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest --config vitest.config.mjs",
    "test:ui": "vitest --config vitest.config.mjs --ui",
    "test:coverage": "vitest --config vitest.config.mjs --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:sync": "prisma db execute --file prisma/sql/add-course-level-columns.sql --schema prisma/schema.prisma",
    "db:sprint5": "prisma db execute --file prisma/sql/sprint-5-notifications.sql --schema prisma/schema.prisma",
    "db:avatar": "prisma db execute --file prisma/sql/avatar-url-longtext.sql --schema prisma/schema.prisma",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}

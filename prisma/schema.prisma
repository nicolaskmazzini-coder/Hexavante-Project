  SYSTEM_ANNOUNCEMENT
  MODERATION_ACTION
  NEW_MESSAGE
  COMMUNITY_REPLY
  SOLUTION_ACCEPTED
}

enum ModerationLogType {
  XP_ADD
  XP_REMOVE
  XP_SET
  LEVEL_SET
  COIN_ADD
  COIN_REMOVE
  COIN_SET
  ROLE_ADD

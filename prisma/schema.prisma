model UserBan {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  moderatorId String    @map("moderator_id")
  reason      String    @db.Text
  expiresAt   DateTime? @map("expires_at")
  liftedAt    DateTime? @map("lifted_at")
  liftedById  String?   @map("lifted_by_id")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User @relation("BanModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([createdAt])
  @@map("user_bans")
}

model UserMute {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  moderatorId String    @map("moderator_id")
  reason      String    @db.Text
  expiresAt   DateTime? @map("expires_at")
  liftedAt    DateTime? @map("lifted_at")
  liftedById  String?   @map("lifted_by_id")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  user      User @relation("MutedUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User @relation("MuteModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([createdAt])
  @@map("user_mutes")
}

model UserWarning {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  moderatorId String   @map("moderator_id")
  reason      String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user      User @relation("WarnedUser", fields: [userId], references: [id], onDelete: Cascade)
  moderator User @relation("WarnModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("user_warnings")
}

model ModerationLog {
  id           String            @id @default(cuid())
  moderatorId  String            @map("moderator_id")
  targetUserId String?           @map("target_user_id")
  action       ModerationLogType
  description  String            @db.Text
  metadata     Json?
  createdAt    DateTime          @default(now()) @map("created_at")

  moderator  User  @relation("ModerationActor", fields: [moderatorId], references: [id], onDelete: Cascade)
  targetUser User? @relation("ModerationTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([moderatorId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@map("moderation_logs")
}

model PlatformSetting {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedById String?  @map("updated_by_id")

  @@map("platform_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model UserNotificationSettings {
  userId              String   @id @map("user_id")
  learningProgress    Boolean  @default(true) @map("learning_progress")
  certificates        Boolean  @default(true)
  courseUpdates       Boolean  @default(true) @map("course_updates")
  messages            Boolean  @default(true)
  community           Boolean  @default(true)
  moderation          Boolean  @default(true)
  coinsAndRewards     Boolean  @default(true) @map("coins_and_rewards")
  rankingSeason       Boolean  @default(true) @map("ranking_season")
  systemAnnouncements Boolean  @default(true) @map("system_announcements")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

model ContentPolicyViolation {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  context     String   @db.VarChar(40)
  field       String   @db.VarChar(80)
  preview     String   @db.VarChar(200)
  matchedTerm String   @map("matched_term") @db.VarChar(80)
  identifier  String?  @db.VarChar(120)
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("content_policy_violations")
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  courseId        String   @map("course_id")
  code            String   @unique
  issuedAt        DateTime @default(now()) @map("issued_at")
  verifiedAt      DateTime? @map("verified_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([code])
  @@map("certificates")
}

enum LiveRoomStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveRoom {
  id          String        @id @default(cuid())
  instructorId String        @map("instructor_id")
  courseId    String?       @map("course_id")
  title       String
  description String?       @db.Text
  videoUrl    String?       @map("video_url")
  videoProvider String?     @map("video_provider")
  scheduledAt DateTime      @map("scheduled_at")
  startedAt   DateTime?     @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  status      LiveRoomStatus @default(SCHEDULED)
  maxParticipants Int?      @map("max_participants")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  instructor   User               @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  course      Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  participants LiveRoomParticipant[]
  messages     LiveChatMessage[]

  @@index([instructorId])
  @@index([courseId])
  @@index([status])
  @@index([scheduledAt])
  @@map("live_rooms")
}

model LiveRoomParticipant {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  room LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("live_room_participants")
}

model LiveChatMessage {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  room LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
  @@index([createdAt])
  @@map("live_chat_messages")
}
